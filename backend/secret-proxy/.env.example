# Rename this file to `.env` and fill in real values.
# Do NOT commit `.env` — it is blocked by the repository's .gitignore.

# ── Required ─────────────────────────────────────────────────────

# Cloudflare Turnstile — required to gate POST /secret/api/create
# Get one at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=

# ── Optional — storage + network ─────────────────────────────────

# Where to store encrypted secret blobs. Default: ./data/secrets
# SECRETS_DIR=./data/secrets

# Listen port. Default: 3100
# PORT=3100

# Listen host. Default: 127.0.0.1 (put a reverse proxy in front).
# Change to 0.0.0.0 to expose the raw Node process (not recommended).
# LISTEN_HOST=127.0.0.1

# Comma-separated list of IPs that bypass the daily create quota (unlimited).
# Useful for internal monitoring or authenticated internal callers.
# SCRT_WHITELIST_IPS=1.2.3.4,5.6.7.8

# ── Optional — email (Mailgun) ───────────────────────────────────
#
# Required only if you want to use:
#   - secret reveal notification (set notifyEmail on POST /secret/api/create)
#   - POST /api/email-report (Email Header Analyzer "receive report by email")
#
# Leave empty to disable both; the tools still work without email.

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=eu      # or `us`
MAIL_FROM=noreply@example.com

# Optional: BCC + Reply-To address added to every outgoing mail.
# BCC_EMAIL=admin@example.com

# ── Optional — email branding (for the minimal HTML wrapper) ─────

# BRAND_NAME=toolbox
# BRAND_URL=https://example.com/
# BRAND_COLOR=#3d5394
